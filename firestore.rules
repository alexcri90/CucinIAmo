rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// 🔐 SECURITY RULES - CucinIAmo
//
// Unica collection: "allowlist"
// - Ogni documento ha come ID un'email in minuscolo
//   (es. allowlist/mario.rossi@gmail.com)
// - Un utente autenticato può leggere SOLO il documento che
//   corrisponde alla propria email (per verificare di essere
//   autorizzato). Nessuno può scrivere dal client: i documenti
//   si aggiungono/rimuovono solo dalla console Firebase.
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    match /allowlist/{email} {
      allow get: if request.auth != null
                 && request.auth.token.email != null
                 && request.auth.token.email.lower() == email;
      allow list, write: if false;
    }

    // Tutto il resto: negato
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
